<!DOCTYPE html>
<html lang="mk">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= title %> – ZitoLuks Admin</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="admin-layout">
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <span class="icon">🍞</span>
      <div><div class="brand">ZitoLuks</div><div class="sub">Администрација</div></div>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-section">Главно</div>
      <a href="/admin" class="nav-item <%= page==='dashboard'?'active':'' %>">
        <span class="ni">📊</span> Контролна Табла
      </a>
      <div class="nav-section">Управување</div>
      <a href="/admin/markets" class="nav-item <%= page==='markets'?'active':'' %>">
        <span class="ni">🏪</span> Пазари
      </a>
      <a href="/admin/articles" class="nav-item <%= page==='articles'?'active':'' %>">
        <span class="ni">🍞</span> Артикли
      </a>
      <a href="/admin/drivers" class="nav-item <%= page==='drivers'?'active':'' %>">
        <span class="ni">🚗</span> Возачи
      </a>
      <a href="/admin/orders" class="nav-item <%= page==='orders'?'active':'' %>">
        <span class="ni">📋</span> Налози
      </a>
      <div class="nav-section">Анализа</div>
      <a href="/admin/reports" class="nav-item <%= page==='reports'?'active':'' %>">
        <span class="ni">📈</span> Извештаи
      </a>
      <a href="/admin/invoices" class="nav-item <%= page==='invoices'?'active':'' %>">
        <span class="ni">🧾</span> Фактури
      </a>
      <a href="/admin/zito-report" class="nav-item <%= page==='zito-report'?'active':'' %>">
        <span class="ni">📊</span> ZitoLuks Извештај
      </a>
    </nav>
    <div class="sidebar-footer">
      <div class="user-info">
        <div class="user-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
        <div><div class="user-name"><%= user.name %></div><div class="user-role">Администратор</div></div>
      </div>
      <a href="/admin/settings" class="btn-outline" style="text-align:center;text-decoration:none;display:block;margin-bottom:8px;font-size:13px;padding:6px">⚙️ Подесувања</a>
      <form method="POST" action="/logout">
        <button type="submit" class="btn-logout">Одјави се</button>
      </form>
    </div>
  </aside>
  <!-- Main -->
  <div class="admin-main">
    <div class="admin-header">
      <div style="display:flex;align-items:center;gap:12px">
        <button class="mobile-menu-btn" onclick="document.querySelector('.sidebar').classList.toggle('show-mobile')">☰</button>
        <h1><%= title %></h1>
      </div>
      <div style="display:flex;align-items:center;gap:12px">
        <span class="date-badge hide-mobile">📅 <%= new Date().toLocaleDateString('mk-MK',{weekday:'long',year:'numeric',month:'long',day:'numeric'}) %></span>
        <form method="POST" action="/logout" class="mobile-logout-form">
          <button type="submit" class="btn btn-outline" style="padding:6px 12px;font-size:12px;color:var(--danger);border-color:#ef444440">Одјави се</button>
        </form>
      </div>
    </div>
    <div class="admin-content">
